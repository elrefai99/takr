{
  "name": "api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "dev": "concurrently \"NODE_ENV=development nodemon -L\" \"NODE_ENV=development npx ts-node ./src/MessageQueue/index.ts\"",
    "dev:local": "concurrently \" nodemon -L\" \"npx ts-node ./src/MessageQueue/index.ts\"",
    "build": "tsc -p tsconfig.build.json",
    "start": "concurrently \"node ./dist/app.js\" \"node ./dist/MessageQueue/index.js\"",
    "test": "jest --detectOpenHandles --runInBand",
    "test:local": "NODE_ENV=development jest",
    "test:e2e": "vitest run --reporter=verbose",
    "test:e2e:watch": "vitest --reporter=verbose",
    "taze:local": "npx taze -r",
    "taze:back": "npx taze major",
    "taze:update": "npx taze major -w",
    "taze:patch": "npx taze patch",
    "compress:ubuntu": "sudo zip -r project.zip .",
    "gen:app": "gen-import --app-config --lazy --map --module-pattern"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@mohamed-elrefai/tsconfigs": "^1.0.2",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^6.0.2",
    "@types/helmet": "^4.0.0",
    "@types/mongoose": "^5.11.97",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^11.0.0",
    "gen-import": "^1.10.9",
    "paseto": "^3.1.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
